class AdvancedEntropyMeasures:
    """
    State-of-the-art entropy measures from 2024-2025 research
    """
    
    def __init__(self, gpu_enabled: bool = False):
        self.gpu_enabled = gpu_enabled and GPU_AVAILABLE
        self.np = cp if self.gpu_enabled else np
    
    def copula_entropy(self, X: np.ndarray, Y: np.ndarray, method: str = 'gaussian') -> float:
        """
        Copula Entropy calculation - State-of-the-art 2024 method
        
        Based on: "Copula entropy-based golden jackal optimization algorithm" 
        Achieves 94.57% accuracy in feature selection
        """
        try:
            if len(X) != len(Y) or len(X) < 10:
                return 0.0
            
            # Convert to GPU arrays if available
            if self.gpu_enabled:
                X = cp.asarray(X)
                Y = cp.asarray(Y)
            
            # Transform to copula domain using ranks
            n = len(X)
            rank_X = stats.rankdata(X) / (n + 1)
            rank_Y = stats.rankdata(Y) / (n + 1)
            
            if method == 'gaussian':
                # Gaussian copula entropy
                from scipy.stats import norm
                u = norm.ppf(rank_X)
                v = norm.ppf(rank_Y)
                
                # Remove infinite values
                mask = np.isfinite(u) & np.isfinite(v)
                if not mask.any():
                    return 0.0
                
                u, v = u[mask], v[mask]
                
                # Calculate correlation
                rho = np.corrcoef(u, v)[0, 1]
                if np.isnan(rho):
                    return 0.0
                
                # Copula entropy formula
                copula_entropy = -0.5 * np.log(1 - rho**2)
                return max(0.0, copula_entropy)
                
            elif method == 'empirical':
                # Empirical copula entropy using k-NN
                return self._empirical_copula_entropy(rank_X, rank_Y)
            
            else:
                return self._parametric_copula_entropy(rank_X, rank_Y, method)
                
        except Exception as e:
            logging.warning(f"Copula entropy calculation error: {e}")
            return 0.0
    
    def _empirical_copula_entropy(self, u: np.ndarray, v: np.ndarray, k: int = 3) -> float:
        """Empirical copula entropy using k-NN method"""
        try:
            n = len(u)
            if n < k + 1:
                return 0.0
            
            # Create copula data points
            copula_data = np.column_stack([u, v])
            
            # Calculate k-NN distances
            from sklearn.neighbors import NearestNeighbors
            nn = NearestNeighbors(n_neighbors=k+1, algorithm='auto')
            nn.fit(copula_data)
            distances, _ = nn.kneighbors(copula_data)
            
            # k-NN entropy estimation
            rho_k = distances[:, k]  # k-th nearest neighbor distance
            
            # Entropy formula
            entropy = np.mean(np.log(rho_k)) + np.log(n-1) - digamma(k) + np.log(4)
            return max(0.0, entropy)
            
        except Exception:
            return 0.0
    
    def _parametric_copula_entropy(self, u: np.ndarray, v: np.ndarray, copula_type: str) -> float:
        """Parametric copula entropy for various copula families"""
        try:
            if copula_type == 'clayton':
                # Clayton copula
                tau = stats.kendalltau(u, v)[0]
                if tau <= 0:
                    return 0.0
                theta = 2 * tau / (1 - tau)
                return theta / (theta + 2)
                
            elif copula_type == 'frank':
                # Frank copula
                tau = stats.kendalltau(u, v)
                if abs(tau) < 0.01:
                    return 0.0
                # Approximation for Frank copula entropy
                return abs(tau) * 1.5
                
            elif copula_type == 'gumbel':
                # Gumbel copula
                tau = stats.kendalltau(u, v)
                if tau <= 0:
                    return 0.0
                theta = 1 / (1 - tau)
                return (theta - 1) / theta
                
            else:
                return 0.0
                
        except Exception:
            return 0.0
    
    def transfer_entropy(self, X: np.ndarray, Y: np.ndarray, lag: int = 1, k: int = 3) -> float:
        """
        Transfer Entropy for dynamic feature relationships
        
        Based on: "Transfer‐entropy‐based dynamic feature selection" (2023)
        """
        try:
            if len(X) < lag + 10 or len(Y) < lag + 10:
                return 0.0
            
            # Create lagged versions
            X_present = X[lag:]
            X_past = X[:-lag]
            Y_past = Y[:-lag]
            
            if len(X_present) != len(X_past) or len(X_past) != len(Y_past):
                return 0.0
            
            # Calculate conditional mutual information
            # TE = I(X_present; Y_past | X_past)
            
            # Using k-NN method for MI estimation
            from sklearn.neighbors import NearestNeighbors
            
            # Create joint distributions
            XYZ = np.column_stack([X_present, Y_past, X_past])  # Joint
            XZ = np.column_stack([X_present, X_past])          # X_present, X_past
            YZ = np.column_stack([Y_past, X_past])            # Y_past, X_past
            Z = X_past.reshape(-1, 1)                         # X_past
            
            # k-NN entropy estimation for each distribution
            def knn_entropy(data, k=k):
                if len(data) < k + 1:
                    return 0.0
                nn = NearestNeighbors(n_neighbors=k+1)
                nn.fit(data)
                distances, _ = nn.kneighbors(data)
                rho_k = distances[:, k]
                return np.mean(np.log(rho_k + 1e-10))
            
            H_XYZ = knn_entropy(XYZ)
            H_XZ = knn_entropy(XZ)
            H_YZ = knn_entropy(YZ)
            H_Z = knn_entropy(Z)
            
            # Transfer entropy
            te = H_XZ + H_YZ - H_XYZ - H_Z
            return max(0.0, te)
            
        except Exception as e:
            logging.warning(f"Transfer entropy calculation error: {e}")
            return 0.0
    
    def approximate_conditional_entropy(self, X: np.ndarray, Y: np.ndarray, 
                                      kernel: str = 'laplacian', sigma: float = 1.0) -> float:
        """
        Approximate Conditional Entropy using Fuzzy Information Granules
        
        Based on: "Feature Selection Using Approximate Conditional Entropy 
        Based on Fuzzy Information Granule" (94.57% accuracy)
        """
        try:
            if len(X) != len(Y) or len(X) < 5:
                return 1.0
            
            # Create fuzzy relation matrix using specified kernel
            if kernel == 'laplacian':
                # Laplacian kernel: faster reduction and smoother tail
                distances = pdist(X.reshape(-1, 1), metric='euclidean')
                dist_matrix = squareform(distances)
                fuzzy_matrix = np.exp(-dist_matrix / sigma)
                
            elif kernel == 'gaussian':
                # Gaussian kernel
                distances = pdist(X.reshape(-1, 1), metric='euclidean')
                dist_matrix = squareform(distances)
                fuzzy_matrix = np.exp(-(dist_matrix**2) / (2 * sigma**2))
                
            else:
                # Default to Laplacian
                distances = pdist(X.reshape(-1, 1), metric='euclidean')
                dist_matrix = squareform(distances)
                fuzzy_matrix = np.exp(-dist_matrix / sigma)
            
            # Create fuzzy information granules
            n = len(X)
            fuzzy_granules = []
            
            for i in range(n):
                granule = fuzzy_matrix[i, :]
                fuzzy_granules.append(granule)
            
            # Calculate approximate conditional entropy
            unique_classes = np.unique(Y)
            entropy = 0.0
            
            for class_val in unique_classes:
                class_mask = (Y == class_val)
                class_prob = np.sum(class_mask) / n
                
                if class_prob == 0:
                    continue
                
                # Calculate approximate accuracy for this class
                total_membership = 0.0
                correct_membership = 0.0
                
                for i in range(n):
                    granule = fuzzy_granules[i]
                    lower_approx = np.min(granule[class_mask]) if np.any(class_mask) else 0
                    upper_approx = np.max(granule)
                    
                    if upper_approx > 0:
                        approx_accuracy = lower_approx / upper_approx
                    else:
                        approx_accuracy = 0
                    
                    total_membership += 1
                    correct_membership += approx_accuracy
                
                if total_membership > 0:
                    avg_accuracy = correct_membership / total_membership
                    # Entropy contribution
                    if avg_accuracy > 0 and avg_accuracy < 1:
                        entropy += class_prob * (-avg_accuracy * np.log2(avg_accuracy) - 
                                                (1-avg_accuracy) * np.log2(1-avg_accuracy))
            
            return entropy
            
        except Exception as e:
            logging.warning(f"Approximate conditional entropy calculation error: {e}")
            return 1.0
    
    def reny_entropy(self, X: np.ndarray, alpha: float = 2.0) -> float:
        """Rényi entropy of order alpha"""
        try:
            if len(X) < 2:
                return 0.0
            
            # Discretize continuous data
            hist, _ = np.histogram(X, bins=int(np.sqrt(len(X))))
            p = hist / np.sum(hist)
            p = p[p > 0]  # Remove zero probabilities
            
            if alpha == 1.0:
                # Shannon entropy limit
                return -np.sum(p * np.log2(p))
            else:
                # Rényi entropy
                return (1 / (1 - alpha)) * np.log2(np.sum(p ** alpha))
                
        except Exception:
            return 0.0
    
    def tsallis_entropy(self, X: np.ndarray, q: float = 2.0) -> float:
        """Tsallis entropy of order q"""
        try:
            if len(X) < 2:
                return 0.0
            
            # Discretize continuous data
            hist, _ = np.histogram(X, bins=int(np.sqrt(len(X))))
            p = hist / np.sum(hist)
            p = p[p > 0]  # Remove zero probabilities
            
            if q == 1.0:
                # Shannon entropy limit
                return -np.sum(p * np.log2(p))
            else:
                # Tsallis entropy
                return (1 / (q - 1)) * (1 - np.sum(p ** q))
                
        except Exception:
            return 0.0


    def _calculate_diversity_penalty(self, X_selected: pd.DataFrame) -> float:
        """Calculate diversity penalty for selected features"""
        try:
            if len(X_selected.columns) <= 1:
                return 0.0
            
            # Calculate correlation matrix
            corr_matrix = X_selected.corr().abs()
            
            # Sum of upper triangle (excluding diagonal)
            upper_triangle = np.triu(corr_matrix, k=1)
            avg_correlation = np.mean(upper_triangle[upper_triangle > 0])
            
            return avg_correlation if not np.isnan(avg_correlation) else 0.0
            
        except Exception:
            return 0.0
    
    def _deep_learning_selection(self, X: pd.DataFrame, y: np.ndarray) -> List[str]:
        """Deep learning-based feature selection"""
        try:
            if not torch.cuda.is_available() and self.config.enable_gpu:
                device = 'cpu'
            else:
                device = 'cuda' if self.config.enable_gpu else 'cpu'
            
            # Prepare data
            X_scaled = StandardScaler().fit_transform(X.values)
            X_tensor = torch.FloatTensor(X_scaled).to(device)
            
            # Create sequence data for BiLSTM
            seq_len = min(20, len(X))  # Use sequence length of 20 or data length
            X_seq = []
            
            for i in range(len(X_tensor) - seq_len + 1):
                X_seq.append(X_tensor[i:i+seq_len])
            
            if not X_seq:
                return []
            
            X_seq = torch.stack(X_seq)
            
            # Initialize BiLSTM model
            if self.bilstm_extractor is None:
                self.bilstm_extractor = BiLSTMAttentionFeatureExtractor(
                    input_dim=X.shape[1],
                    hidden_dim=64,
                    num_layers=2,
                    dropout=0.2
                ).to(device)
            
            # Training mode
            self.bilstm_extractor.eval()
            
            with torch.no_grad():
                importance_scores, _ = self.bilstm_extractor(X_seq[:100])  # Use first 100 sequences
                importance_scores = torch.mean(importance_scores, dim=0)  # Average across sequences
                importance_scores = importance_scores.cpu().numpy()
            
            # Select top features
            n_select = min(self.config.max_features, len(X.columns))
            top_indices = np.argsort(importance_scores)[-n_select:]
            
            return [X.columns[i] for i in top_indices]
            
        except Exception as e:
            logging.warning(f"Deep learning selection error: {e}")
            return []
    
    def _create_ensemble_selection(self, optimization_results: Dict, X: pd.DataFrame, y: np.ndarray) -> List[str]:
        """Create ensemble selection from multiple optimization results"""
        try:
            # Collect all selected features with their frequencies
            feature_votes = defaultdict(int)
            total_methods = len(optimization_results)
            
            for method_name, result in optimization_results.items():
                features = result['features']
                fitness = result['fitness']
                
                # Weight by inverse fitness (lower fitness = better)
                weight = 1.0 / (abs(fitness) + 1e-6)
                
                for feature in features:
                    feature_votes[feature] += weight
            
            # Also add top features from direct scoring
            top_scored_features = sorted(
                self.feature_scores.items(),
                key=lambda x: x[1].get('ultra_advanced_score', 0),
                reverse=True
            )[:self.config.max_features]
            
            for feature_name, scores in top_scored_features:
                feature_votes[feature_name] += scores.get('ultra_advanced_score', 0)
            
            # Select top voted features
            sorted_features = sorted(
                feature_votes.items(),
                key=lambda x: x[67],
                reverse=True
            )
            
            # Apply correlation filtering
            selected_features = []
            for feature_name, vote_score in sorted_features:
                if len(selected_features) >= self.config.max_features:
                    break
                
                # Check correlation with already selected features
                if self._is_feature_acceptable(feature_name, selected_features, X):
                    selected_features.append(feature_name)
            
            # Ensure minimum number of features
            if len(selected_features) < 5 and len(sorted_features) >= 5:
                selected_features = [f[0] for f in sorted_features[:5]]
            
            return selected_features
            
        except Exception as e:
            logging.warning(f"Ensemble selection error: {e}")
            # Fallback to top scored features
            return list(sorted(
                self.feature_scores.keys(),
                key=lambda x: self.feature_scores[x].get('ultra_advanced_score', 0),
                reverse=True
            ))[:self.config.max_features]
    
    def _is_feature_acceptable(self, feature_name: str, selected_features: List[str], X: pd.DataFrame) -> bool:
        """Check if feature is acceptable (not highly correlated with selected)"""
        try:
            if not selected_features:
                return True
            
            feature_data = X[feature_name]
            
            for selected_feature in selected_features:
                selected_data = X[selected_feature]
                
                # Calculate correlation
                corr = abs(feature_data.corr(selected_data))
                
                if not np.isnan(corr) and corr > self.config.correlation_threshold:
                    return False
            
            return True
            
        except Exception:
            return True
    

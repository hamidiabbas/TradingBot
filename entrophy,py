class BiLSTMAttentionFeatureExtractor(nn.Module):
    """
    BiLSTM with Attention for Advanced Feature Extraction
    
    Based on: "Research and Application of Improved LSTM Based Algorithm" 
    (94.57% accuracy, 2025)
    """
    
    def __init__(self, input_dim: int, hidden_dim: int = 64, 
                 num_layers: int = 2, dropout: float = 0.2):
        super().__init__()
        
        self.hidden_dim = hidden_dim
        self.num_layers = num_layers
        
        # BiLSTM layer
        self.bilstm = nn.LSTM(
            input_size=input_dim,
            hidden_size=hidden_dim,
            num_layers=num_layers,
            batch_first=True,
            dropout=dropout if num_layers > 1 else 0,
            bidirectional=True
        )
        
        # Attention mechanism
        self.attention = nn.MultiheadAttention(
            embed_dim=hidden_dim * 2,  # Bidirectional
            num_heads=8,
            dropout=dropout,
            batch_first=True
        )
        
        # Feature importance layer
        self.feature_importance = nn.Sequential(
            nn.Linear(hidden_dim * 2, hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(hidden_dim, 1),
            nn.Sigmoid()
        )
    
    def forward(self, x):
        """
        Forward pass
        
        Args:
            x: Input tensor of shape (batch_size, seq_len, features)
        
        Returns:
            feature_importance: Importance scores for each feature
        """
        batch_size, seq_len, features = x.size()
        
        # BiLSTM processing
        lstm_out, _ = self.bilstm(x)
        
        # Attention mechanism
        attn_out, attn_weights = self.attention(lstm_out, lstm_out, lstm_out)
        
        # Global average pooling
        pooled = torch.mean(attn_out, dim=1)  # (batch_size, hidden_dim*2)
        
        # Feature importance scores
        importance_scores = self.feature_importance(pooled)
        
        return importance_scores.squeeze(), attn_weights

class VisionTransformerFeatureSelector:
    """
    Vision Transformer adapted for Financial Time Series Feature Selection
    
    Based on: "Frequency Stability Prediction of Power Systems Using 
    Vision Transformer and Copula Entropy" (SOTA performance, 2022)
    """
    
    def __init__(self, feature_dim: int, patch_size: int = 4, 
                 d_model: int = 256, n_heads: int = 8, n_layers: int = 6):
        self.feature_dim = feature_dim
        self.patch_size = patch_size
        self.d_model = d_model
        self.n_heads = n_heads
        self.n_layers = n_layers
        
        if not TRANSFORMERS_AVAILABLE:
            print("⚠️ Transformers not available - using simplified ViT")
            self.model = self._create_simplified_vit()
        else:
            self.model = self._create_advanced_vit()
    
    def _create_simplified_vit(self):
        """Simplified ViT implementation"""
        return nn.Sequential(
            nn.Linear(self.feature_dim, self.d_model),
            nn.ReLU(),
            nn.Dropout(0.1),
            nn.Linear(self.d_model, self.d_model // 2),
            nn.ReLU(),
            nn.Linear(self.d_model // 2, self.feature_dim),
            nn.Sigmoid()
        )
    
    def _create_advanced_vit(self):
        """Advanced ViT with transformer layers"""
        from torch.nn import TransformerEncoder, TransformerEncoderLayer
        
        # Patch embedding
        self.patch_embed = nn.Linear(self.patch_size, self.d_model)
        
        # Positional encoding
        self.pos_embed = nn.Parameter(torch.randn(1, self.feature_dim // self.patch_size, self.d_model))
        
        # Transformer encoder
        encoder_layer = TransformerEncoderLayer(
            d_model=self.d_model,
            nhead=self.n_heads,
            dim_feedforward=self.d_model * 4,
            dropout=0.1,
            batch_first=True
        )
        
        self.transformer = TransformerEncoder(encoder_layer, num_layers=self.n_layers)
        
        # Feature importance head
        self.importance_head = nn.Sequential(
            nn.LayerNorm(self.d_model),
            nn.Linear(self.d_model, 1),
            nn.Sigmoid()
        )
        
        return self
    
    def forward(self, x):
        """Forward pass for feature importance scoring"""
        if not TRANSFORMERS_AVAILABLE:
            return self.model(x)
        
        batch_size = x.size(0)
        
        # Reshape for patches
        x_patches = x.view(batch_size, -1, self.patch_size)
        
        # Patch embedding
        x_embed = self.patch_embed(x_patches)
        
        # Add positional encoding
        x_embed += self.pos_embed
        
        # Transformer encoding
        x_encoded = self.transformer(x_embed)
        
        # Feature importance
        importance = self.importance_head(x_encoded)
        
        # Reshape back to feature dimension
        importance = importance.view(batch_size, -1)
        
        return importance


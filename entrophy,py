                    print(f"   ✅ {feature_name}: Ultra Score = {scores['ultra_advanced_score']:.4f}")
        
        print(f"   📊 Valid features processed: {valid_count}/{n_features}")
        
        self.feature_scores = feature_scores
        self.selection_time = time.time() - start_time
        
        return feature_scores
    
    def _calculate_mutual_information(self, X: np.ndarray, y: np.ndarray) -> float:
        """Calculate mutual information using k-NN method"""
        try:
            from sklearn.feature_selection import mutual_info_classif
            X_reshaped = X.reshape(-1, 1)
            mi = mutual_info_classif(X_reshaped, y, random_state=42)
            return mi[0]
        except Exception:
            return 0.0
    
    def _calculate_information_gain(self, X: np.ndarray, y: np.ndarray) -> float:
        """Calculate information gain"""
        try:
            # Calculate entropy of y
            unique_y, counts_y = np.unique(y, return_counts=True)
            entropy_y = -np.sum((counts_y / len(y)) * np.log2(counts_y / len(y)))
            
            # Discretize X
            X_discrete = pd.qcut(X, q=5, duplicates='drop', labels=False)
            
            # Calculate conditional entropy
            conditional_entropy = 0.0
            unique_x = np.unique(X_discrete)
            
            for x_val in unique_x:
                mask = X_discrete == x_val
                if not mask.any():
                    continue
                
                y_subset = y[mask]
                prob_x = np.sum(mask) / len(X_discrete)
                
                if len(y_subset) > 0:
                    unique_y_subset, counts_y_subset = np.unique(y_subset, return_counts=True)
                    entropy_y_given_x = -np.sum((counts_y_subset / len(y_subset)) * 
                                               np.log2(counts_y_subset / len(y_subset)))
                    conditional_entropy += prob_x * entropy_y_given_x
            
            return max(0.0, entropy_y - conditional_entropy)
            
        except Exception:
            return 0.0
    
    def _safe_correlation(self, X: np.ndarray, y: np.ndarray) -> float:
        """Safe correlation calculation"""
        try:
            if np.issubdtype(X.dtype, np.number) and np.issubdtype(y.dtype, np.number):
                corr = np.corrcoef(X, y)[0, 1]
                return abs(corr) if not np.isnan(corr) else 0.0
            else:
                return 0.0
        except:
            return 0.0
    
    def _calculate_ultra_advanced_score(self, scores: Dict[str, float]) -> float:
        """Calculate ultra-advanced combined score"""
        try:
            # Weighted combination of all entropy measures
            copula_score = (scores.get('copula_entropy_gaussian', 0) + 
                          scores.get('copula_entropy_empirical', 0) + 
                          scores.get('copula_entropy_clayton', 0)) / 3
            
            transfer_score = scores.get('transfer_entropy', 0)
            
            approximate_score = (scores.get('approximate_conditional_laplacian', 0) + 
                               scores.get('approximate_conditional_gaussian', 0)) / 2
            
            classical_score = (scores.get('mutual_information', 0) + 
                             scores.get('information_gain', 0)) / 2
            
            advanced_score = (scores.get('renyi_entropy', 0) + 
                            scores.get('tsallis_entropy', 0)) / 2
            
            statistical_score = (scores.get('correlation', 0) + 
                               min(scores.get('variance', 0), 1.0)) / 2
            
            # Ultra-advanced weighted combination
            ultra_score = (
                copula_score * self.config.copula_entropy_weight +
                transfer_score * self.config.transfer_entropy_weight +
                classical_score * self.config.mutual_information_weight +
                approximate_score * self.config.approximate_entropy_weight +
                (advanced_score + statistical_score) * 0.05
            )
            
            return ultra_score
            
        except Exception:
            return 0.0
    
    def optimize_feature_selection(self, X: pd.DataFrame, y: np.ndarray) -> List[str]:
        """
        Ultra-advanced feature selection using meta-heuristic optimization
        """
        print(f"\n🚀 ULTRA-ADVANCED OPTIMIZATION PROCESS...")
        
        # Calculate comprehensive scores first
        if not self.feature_scores:
            self.calculate_comprehensive_scores(X, y)
        
        feature_names = list(X.columns)
        n_features = len(feature_names)
        
        # Define objective function for optimization
        def objective_function(binary_mask):
            """Objective function for meta-heuristic optimizers"""
            try:
                # Convert continuous values to binary
                binary_features = binary_mask > 0.5
                
                if not binary_features.any():
                    return float('inf')  # No features selected
                
                selected_indices = np.where(binary_features)[0]
                selected_features = [feature_names[i] for i in selected_indices]
                
                # Calculate fitness based on selected features
                fitness_score = 0.0
                n_selected = len(selected_features)
                
                # Feature quality score (higher is better, so we minimize negative)
                quality_scores = []
                for feature in selected_features:
                    if feature in self.feature_scores:
                        quality_scores.append(self.feature_scores[feature]['ultra_advanced_score'])
                    else:
                        quality_scores.append(0.0)
                
                avg_quality = np.mean(quality_scores) if quality_scores else 0.0
                
                # Diversity score (minimize redundancy)
                diversity_penalty = self._calculate_diversity_penalty(X[selected_features])
                
                # Size penalty (prefer smaller subsets)
                size_penalty = n_selected / n_features
                
                # Combined fitness (minimize)
                fitness_score = -(avg_quality * 0.7 - diversity_penalty * 0.2 - size_penalty * 0.1)
                
                return fitness_score
                
            except Exception as e:
                logging.warning(f"Objective function error: {e}")
                return float('inf')
        
        # Run optimizers
        optimization_results = {}
        
        # 1. Golden Jackal Optimization
        if self.config.use_golden_jackal:
            print("🦅 Running Golden Jackal Optimization...")

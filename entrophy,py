    def calculate_comprehensive_scores(self, X: pd.DataFrame, y: np.ndarray) -> Dict[str, Dict[str, float]]:
        """
        Calculate comprehensive entropy-based feature scores using all methods
        """
        start_time = time.time()
        n_features = len(X.columns)
        feature_scores = {}
        
        print(f"\n🔬 CALCULATING COMPREHENSIVE ENTROPY SCORES...")
        print(f"   📊 Features: {n_features}")
        print(f"   🎯 Samples: {len(y)}")
        
        # Prepare target variable
        if y.dtype == 'object' or not np.issubdtype(y.dtype, np.number):
            label_encoder = LabelEncoder()
            y_encoded = label_encoder.fit_transform(y)
        else:
            y_encoded = y.copy()
        
        # Convert to discrete classes if too many unique values
        if len(np.unique(y_encoded)) > 10:
            y_encoded = pd.qcut(y_encoded, q=5, duplicates='drop', labels=False)
        
        # Parallel processing setup
        def calculate_feature_scores(feature_name):
            try:
                feature_data = X[feature_name].values
                scores = {}
                
                # Handle missing values
                mask = pd.notna(feature_data)
                if not mask.any() or len(feature_data[mask]) < 10:
                    return feature_name, None
                
                clean_feature = feature_data[mask]
                clean_target = y_encoded[mask]
                
                # 1. Copula Entropy (State-of-the-art 2024)
                scores['copula_entropy_gaussian'] = self.entropy_measures.copula_entropy(
                    clean_feature, clean_target, method='gaussian'
                )
                scores['copula_entropy_empirical'] = self.entropy_measures.copula_entropy(
                    clean_feature, clean_target, method='empirical'
                )
                scores['copula_entropy_clayton'] = self.entropy_measures.copula_entropy(
                    clean_feature, clean_target, method='clayton'
                )
                
                # 2. Transfer Entropy
                if len(clean_feature) > 20:  # Need enough data for lag
                    scores['transfer_entropy'] = self.entropy_measures.transfer_entropy(
                        clean_feature, clean_target, lag=1
                    )
                else:
                    scores['transfer_entropy'] = 0.0
                
                # 3. Approximate Conditional Entropy
                scores['approximate_conditional_laplacian'] = self.entropy_measures.approximate_conditional_entropy(
                    clean_feature, clean_target, kernel='laplacian', sigma=1.0
                )
                scores['approximate_conditional_gaussian'] = self.entropy_measures.approximate_conditional_entropy(
                    clean_feature, clean_target, kernel='gaussian', sigma=1.0
                )
                
                # 4. Advanced Entropy Measures
                scores['renyi_entropy'] = self.entropy_measures.reny_entropy(clean_feature, alpha=2.0)
                scores['tsallis_entropy'] = self.entropy_measures.tsallis_entropy(clean_feature, q=2.0)
                
                # 5. Classical Information Measures
                scores['mutual_information'] = self._calculate_mutual_information(clean_feature, clean_target)
                scores['information_gain'] = self._calculate_information_gain(clean_feature, clean_target)
                
                # 6. Statistical Measures
                scores['correlation'] = self._safe_correlation(clean_feature, clean_target)
                scores['variance'] = np.var(clean_feature) if len(np.unique(clean_feature)) > 1 else 0.0
                
                # 7. Advanced Combined Score
                scores['ultra_advanced_score'] = self._calculate_ultra_advanced_score(scores)
                
                return feature_name, scores
                
            except Exception as e:
                logging.warning(f"Error processing feature {feature_name}: {e}")
                return feature_name, None
        
        # Execute calculations
        if self.config.enable_parallel:
            with ThreadPoolExecutor(max_workers=min(8, n_features)) as executor:
                results = list(executor.map(calculate_feature_scores, X.columns))
        else:
            results = [calculate_feature_scores(col) for col in X.columns]
        
        # Process results
        valid_count = 0
        for feature_name, scores in results:
            if scores is not None:
                feature_scores[feature_name] = scores

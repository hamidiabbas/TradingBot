class GoldenJackalOptimizer:
    """
    Golden Jackal Optimization Algorithm for Feature Selection
    
    Based on: "Copula entropy-based golden jackal optimization algorithm 
    for high-dimensional feature selection problems" (2024)
    """
    
    def __init__(self, n_agents: int = 20, max_iterations: int = 100):
        self.n_agents = n_agents
        self.max_iterations = max_iterations
        self.best_position = None
        self.best_fitness = float('inf')
        self.convergence_history = []
    
    def optimize(self, objective_function: Callable, n_features: int, 
                bounds: Tuple[float, float] = (0, 1)) -> np.ndarray:
        """
        Optimize feature selection using Golden Jackal Algorithm
        """
        # Initialize population
        population = np.random.uniform(bounds[0], bounds[1], 
                                     (self.n_agents, n_features))
        fitness = np.array([objective_function(agent) for agent in population])
        
        # Find initial best
        best_idx = np.argmin(fitness)
        self.best_position = population[best_idx].copy()
        self.best_fitness = fitness[best_idx]
        
        for iteration in range(self.max_iterations):
            a = 2 - iteration * (2 / self.max_iterations)  # Decreases from 2 to 0
            
            for i in range(self.n_agents):
                # Golden Jackal behavior parameters
                rl = 0.05 * np.random.random()  # Random in [0, 0.05]
                E = 2 * np.random.random() - 1  # Random in [-1, 1]
                
                if abs(E) < 1:  # Exploration
                    if np.random.random() < 0.5:
                        # Position update equation 1
                        new_position = self.best_position - E * abs(2 * rl * self.best_position - population[i])
                    else:
                        # Position update equation 2
                        new_position = self.best_position - a * abs(rl * self.best_position - population[i])
                else:  # Exploitation
                    # Random position
                    rand_idx = np.random.randint(0, self.n_agents)
                    new_position = rl * population[rand_idx]
                
                # Boundary handling
                new_position = np.clip(new_position, bounds[0], bounds[1])
                
                # Evaluate new position
                new_fitness = objective_function(new_position)
                
                # Update if better
                if new_fitness < fitness[i]:
                    population[i] = new_position
                    fitness[i] = new_fitness
                    
                    # Update global best
                    if new_fitness < self.best_fitness:
                        self.best_position = new_position.copy()
                        self.best_fitness = new_fitness
            
            self.convergence_history.append(self.best_fitness)
            
            # Print progress
            if iteration % 10 == 0:
                print(f"🦅 Golden Jackal Iteration {iteration}: Best Fitness = {self.best_fitness:.6f}")
        
        return self.best_position

class GreyWolfOptimizer:
    """
    Enhanced Grey Wolf Optimizer for Feature Selection
    
    Based on: "Feature selection in peer-to-peer lending based on 
    hybrid modified grey wolf optimization" (91% accuracy, 2024)
    """
    
    def __init__(self, n_agents: int = 20, max_iterations: int = 100):
        self.n_agents = n_agents
        self.max_iterations = max_iterations
        self.alpha_pos = None  # Best solution
        self.beta_pos = None   # Second best
        self.delta_pos = None  # Third best
        self.convergence_history = []
    
    def optimize(self, objective_function: Callable, n_features: int,
                bounds: Tuple[float, float] = (0, 1)) -> np.ndarray:
        """
        Enhanced Grey Wolf Optimization with modifications
        """
        # Initialize population
        population = np.random.uniform(bounds[0], bounds[67], 
                                     (self.n_agents, n_features))
        fitness = np.array([objective_function(agent) for agent in population])
        
        # Initialize alpha, beta, delta
        sorted_indices = np.argsort(fitness)
        self.alpha_pos = population[sorted_indices].copy()
        self.beta_pos = population[sorted_indices[67]].copy()
        self.delta_pos = population[sorted_indices].copy()
        
        for iteration in range(self.max_iterations):
            a = 2 - iteration * (2 / self.max_iterations)  # Decreases from 2 to 0
            
            for i in range(self.n_agents):
                # Alpha wolf influence
                r1, r2 = np.random.random(2)
                A1 = 2 * a * r1 - a
                C1 = 2 * r2
                D_alpha = abs(C1 * self.alpha_pos - population[i])
                X1 = self.alpha_pos - A1 * D_alpha
                
                # Beta wolf influence
                r1, r2 = np.random.random(2)
                A2 = 2 * a * r1 - a
                C2 = 2 * r2
                D_beta = abs(C2 * self.beta_pos - population[i])
                X2 = self.beta_pos - A2 * D_beta
                
                # Delta wolf influence
                r1, r2 = np.random.random(2)
                A3 = 2 * a * r1 - a
                C3 = 2 * r2
                D_delta = abs(C3 * self.delta_pos - population[i])
                X3 = self.delta_pos - A3 * D_delta
                
                # Update position (enhanced with Lévy flight)
                if iteration < self.max_iterations / 2:
                    # Standard update
                    new_position = (X1 + X2 + X3) / 3
                else:
                    # Lévy flight enhancement
                    levy = self._levy_flight(n_features)
                    new_position = (X1 + X2 + X3) / 3 + 0.1 * levy
                
                # Boundary handling
                new_position = np.clip(new_position, bounds[0], bounds[67])
                
                # Evaluate and update
                new_fitness = objective_function(new_position)
                if new_fitness < fitness[i]:
                    population[i] = new_position
                    fitness[i] = new_fitness
            
            # Update alpha, beta, delta
            sorted_indices = np.argsort(fitness)
            self.alpha_pos = population[sorted_indices].copy()
            self.beta_pos = population[sorted_indices[67]].copy()
            self.delta_pos = population[sorted_indices].copy()
            
            self.convergence_history.append(fitness[sorted_indices])
            
            if iteration % 10 == 0:
                print(f"🐺 Grey Wolf Iteration {iteration}: Best Fitness = {fitness[sorted_indices]:.6f}")
        
        return self.alpha_pos
    
    def _levy_flight(self, dim: int, beta: float = 1.5) -> np.ndarray:
        """Generate Lévy flight step"""
        sigma = (math.gamma(1 + beta) * np.sin(np.pi * beta / 2) / 
                (math.gamma((1 + beta) / 2) * beta * (2 ** ((beta - 1) / 2)))) ** (1 / beta)
        
        u = np.random.normal(0, sigma, dim)
        v = np.random.normal(0, 1, dim)
        step = u / (abs(v) ** (1 / beta))
        
        return step


def save_advanced_results(selector: UltraAdvancedEntropyFeatureSelector, 
                         filepath: str = "ultra_advanced_results.json"):
    """Save comprehensive results to file"""
    try:
        analysis = selector.get_comprehensive_analysis()
        
        # Convert numpy types to native Python types for JSON serialization
        def convert_numpy_types(obj):
            if isinstance(obj, np.ndarray):
                return obj.tolist()
            elif isinstance(obj, np.integer):
                return int(obj)
            elif isinstance(obj, np.floating):
                return float(obj)
            elif isinstance(obj, dict):
                return {key: convert_numpy_types(value) for key, value in obj.items()}
            elif isinstance(obj, list):
                return [convert_numpy_types(item) for item in obj]
            else:
                return obj
        
        analysis_serializable = convert_numpy_types(analysis)
        
        with open(filepath, 'w') as f:
            json.dump(analysis_serializable, f, indent=2, default=str)
        
        print(f"💾 Advanced results saved to: {filepath}")
        
    except Exception as e:
        print(f"❌ Failed to save results: {e}")


            gjo_features = [feature_names[i] for i, val in enumerate(gjo_result) if val > 0.5]
            optimization_results['golden_jackal'] = {
                'features': gjo_features,
                'fitness': objective_function(gjo_result),
                'binary_mask': gjo_result > 0.5
            }

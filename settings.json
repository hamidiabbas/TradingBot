{
    "python.defaultInterpreterPath": "./trading_env/Scripts/python.exe",
    "python.terminal.activateEnvironment": true,
    "python.envFile": "${workspaceFolder}/.env",
    "files.exclude": {
        "**/__pycache__": true,
        "**/node_modules": true,
        "trading_env": true,
        "*.pyc": true
    },
    "python.linting.enabled": true,
    "python.linting.pylintEnabled": true,
    "python.formatting.provider": "black",
    "python.testing.pytestEnabled": true,
    "python.testing.pytestArgs": [
        "tests"
    ],
    "terminal.integrated.shell.windows": "cmd.exe"
}
// This file is used to configure the Python environment and settings for the TradingBot project in Visual Studio Code.
// It specifies the Python interpreter, environment activation, linting, formatting, and testing configurations.
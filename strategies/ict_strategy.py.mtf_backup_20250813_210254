                        'h4_bias': h4_analysis.get('bias'),
                        'h1_patterns': h1_analysis.get('pattern_count', 0),
                        'confluences': confluences,
                        'confluence_total': total_confluence,
                        'liquidity_context': len(liquidity_context.get('swept_levels', []))
                    },
                    'methodology': 'complete_ict_mtf'
                }
            
            # Generate trade levels
            trade_levels = self._calculate_ict_trade_levels(

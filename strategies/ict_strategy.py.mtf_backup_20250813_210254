    def _generate_complete_ict_signal(self, daily_analysis: Dict, h4_analysis: Dict, 
                                    h1_analysis: Dict, m15_analysis: Dict, 
                                    confluences: Dict, liquidity_context: Dict, symbol: str) -> Dict[str, Any]:
        """Generate complete ICT signal with all methodology components"""
        
        try:
            # Base signal from M15 precision analysis
            base_signal = m15_analysis['entry_signal']
            base_confidence = base_signal.get('confidence', 0.0)
            
            # Apply confluence multipliers
            total_confluence = sum(confluences.values())
            confluence_multiplier = 1 + (total_confluence / 2)  # Max 1.5x multiplier
            
            # Apply liquidity context
            liquidity_bonus = 0.0
            if m15_analysis.get('liquidity_sweep'):
                liquidity_bonus += 0.2  # Recent sweep bonus
            
            # Calculate final confidence
            final_confidence = min(1.0, (base_confidence * confluence_multiplier) + liquidity_bonus)
            
            # Signal validation - ICT requires strong confluence
            if final_confidence < 0.65:  # Higher threshold for ICT
                return {
                    'signal': 'HOLD',
                    'confidence': final_confidence,
                    'reason': 'Insufficient ICT confluence for entry',
                    'analysis': {

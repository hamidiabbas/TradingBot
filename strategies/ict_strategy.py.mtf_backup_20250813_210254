    def _calculate_advanced_ict_confluences(self, mtf_data: Dict[str, pd.DataFrame], 
                                          daily_analysis: Dict, h4_analysis: Dict, h1_analysis: Dict) -> Dict[str, float]:
        """Calculate advanced ICT confluences across all timeframes"""
        
        confluences = {
            'trend_alignment': 0.0,
            'structure_confluence': 0.0,
            'time_confluence': 0.0,
            'liquidity_confluence': 0.0,
            'order_flow_confluence': 0.0,
            'session_confluence': 0.0
        }
        
        try:
            # Trend alignment across timeframes
            daily_trend = daily_analysis.get('trend_direction', 'NEUTRAL')
            h4_bias = h4_analysis.get('bias', 'NEUTRAL')
            
            if daily_trend == h4_bias and daily_trend != 'NEUTRAL':
                confluences['trend_alignment'] = 0.3
            
            # Structure confluence
            structure_quality = (
                daily_analysis.get('structure_quality', 0) +
                h1_analysis.get('structure_strength', 0)
            ) / 2
            confluences['structure_confluence'] = min(0.3, structure_quality)
            
            # Time confluence (ICT kill zones)
            if 'H1' in mtf_data:
                current_time = mtf_data['H1'].index[-1]
                confluences['time_confluence'] = self._calculate_time_confluence(current_time)
            
            # Liquidity confluence
            liquidity_score = len(h4_analysis.get('liquidity_levels', [])) * 0.05
            confluences['liquidity_confluence'] = min(0.2, liquidity_score)
            
            # Order flow confluence
            daily_order_flow = daily_analysis.get('order_flow', {}).get('net_flow', 0)
            confluences['order_flow_confluence'] = min(0.2, abs(daily_order_flow) * 0.1)
            
            # Session confluence
            confluences['session_confluence'] = self._calculate_session_confluence()
            
        except Exception as e:
            self.logger.error(f"Error calculating advanced ICT confluences: {e}")
        
        return confluences
    

    def validate_mtf_data(self, mtf_data: Dict[str, pd.DataFrame], required_tfs: List[str]) -> bool:
        """Validate multi-timeframe data availability with ICT requirements"""
        
        if not mtf_data:
            return False
        
        # Check if we have at least 75% of required timeframes
        available_tfs = [tf for tf in required_tfs if tf in mtf_data and not mtf_data[tf].empty and len(mtf_data[tf]) >= 50]
        
        coverage = len(available_tfs) / len(required_tfs)
        
        if coverage >= 0.75:  # 75% coverage minimum
            return True
        
        # Special case: if we have H1 and either H4 or D1, we can proceed
        if 'H1' in available_tfs and ('H4' in available_tfs or 'D1' in available_tfs):
            return True
        
        return False
    
    def get_timeframe_data(self, mtf_data: Dict[str, pd.DataFrame], timeframe: str, lookback: int = None) -> pd.DataFrame:
        """Get timeframe data with ICT-specific preprocessing"""
        
        if timeframe not in mtf_data:
            raise ValueError(f"Timeframe {timeframe} not available in MTF data")
        
        data = mtf_data[timeframe].copy()
        
        # Apply lookback
        if lookback and len(data) > lookback:
            data = data.tail(lookback)
        
        # Add ICT-specific indicators
        data = self._add_ict_indicators(data, timeframe)
        
        # Ensure required attributes
        data.timeframe = timeframe
        data.symbol = getattr(data, 'symbol', 'UNKNOWN')
        
        return data
    
    def _add_ict_indicators(self, data: pd.DataFrame, timeframe: str) -> pd.DataFrame:
        """Add ICT-specific indicators based on timeframe"""
        
        try:
            # Basic indicators for all timeframes
            data['ema_9'] = data['close'].ewm(span=9).mean()
            data['ema_21'] = data['close'].ewm(span=21).mean()
            data['ema_50'] = data['close'].ewm(span=50).mean()
            
            # Volume analysis (use tick_volume if volume not available)
            volume_col = 'volume' if 'volume' in data.columns else 'tick_volume'
            if volume_col in data.columns:
                data['volume_sma'] = data[volume_col].rolling(20).mean()
                data['volume_ratio'] = data[volume_col] / data['volume_sma']
                data['high_volume'] = data['volume_ratio'] > 1.5
            
            # ATR for volatility analysis
            data['atr'] = self._calculate_atr(data, 14)
            
            # Timeframe-specific indicators
            if timeframe in ['D1', 'H4']:
                # Higher timeframe structure indicators
                data['swing_high'] = data['high'].rolling(5, center=True).max()
                data['swing_low'] = data['low'].rolling(5, center=True).min()
                
            elif timeframe in ['H1', 'M15']:
                # Lower timeframe precision indicators
                data['displacement'] = abs(data['close'] - data['open']) / data['atr']
                data['strong_candle'] = data['displacement'] > 1.5
            
            return data.fillna(method='ffill').fillna(0)
            
        except Exception as e:
            self.logger.error(f"Error adding ICT indicators: {e}")
            return data
    
    def _calculate_atr(self, data: pd.DataFrame, period: int = 14) -> pd.Series:
        """Calculate Average True Range"""
        try:
            high_low = data['high'] - data['low']
            high_close = np.abs(data['high'] - data['close'].shift())
            low_close = np.abs(data['low'] - data['close'].shift())
            
            true_range = pd.concat([high_low, high_close, low_close], axis=1).max(axis=1)
            return true_range.rolling(period).mean()
        except:
            return pd.Series(0, index=data.index)
    
